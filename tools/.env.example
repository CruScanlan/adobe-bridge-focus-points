# Copy to tools/.env and adjust for your machine. All vars are optional;
# the script falls back to sensible defaults when a var is unset.

# Repo root. Defaults to the parent of tools/, so usually leave unset.
#REPO="/c/path/to/adobe-bridge-focus-points"

# CEP user extensions folder. Default: $APPDATA/Adobe/CEP/extensions
#CEP_EXT="/c/Users/<you>/AppData/Roaming/Adobe/CEP/extensions"

# Scratch dir for staging + the .zxp + the CEP log.
# Default: $LOCALAPPDATA/Temp (or /tmp)
#TMPDIR="/c/Users/<you>/AppData/Local/Temp"

# Self-signed dev cert password and extension id.
#CERT_PASS="bfp-dev-pass"
#EXT_ID="com.cru.bridgefocuspoints"
